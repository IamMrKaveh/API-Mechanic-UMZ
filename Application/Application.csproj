<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

	<ItemGroup>
		<!-- Security -->
		<PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.13" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Google" Version="9.0.13" />

		<!-- Data Access -->
		<PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.13" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Relational" Version="9.0.13" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.13">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="9.0.13">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>

		<PackageReference Include="Npgsql" Version="9.0.0" />
		<PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.0" />
		<PackageReference Include="Dapper" Version="2.1.66" />

		<!-- Caching -->
		<PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" Version="9.0.13" />
		<PackageReference Include="StackExchange.Redis" Version="2.10.14" />
		<PackageReference Include="Microsoft.AspNetCore.DataProtection.StackExchangeRedis" Version="9.0.13" />

		<!-- Messaging -->
		<PackageReference Include="MassTransit" Version="8.2.3" />

		<!-- Background Jobs -->
		<PackageReference Include="Quartz" Version="3.13.0" />

		<!-- HTTP Resilience -->
		<PackageReference Include="Microsoft.Extensions.Http.Polly" Version="9.0.13" />
		<PackageReference Include="Polly" Version="8.4.1" />

		<!-- Validation -->
		<PackageReference Include="FluentValidation" Version="12.1.1" />
		<PackageReference Include="FluentValidation.DependencyInjectionExtensions" Version="12.1.1" />

		<!-- Mediator -->
		<PackageReference Include="MediatR" Version="14.0.0" />

		<!-- Result Pattern -->
		<PackageReference Include="ErrorOr" Version="2.0.1" />

		<!-- Mapping -->
		<PackageReference Include="Mapster" Version="7.4.0" />

		<!-- Logging -->
		<PackageReference Include="Serilog.AspNetCore" Version="9.0.0" />
		<PackageReference Include="Serilog.Enrichers.Environment" Version="3.0.1" />
		<PackageReference Include="Serilog.Enrichers.Process" Version="3.0.0" />
		<PackageReference Include="Serilog.Enrichers.Thread" Version="4.0.0" />
		<PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
		<PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />

		<!-- Error Handling -->
		<PackageReference Include="Hellang.Middleware.ProblemDetails" Version="6.5.1" />

		<!-- Dependency Injection -->
		<PackageReference Include="Scrutor" Version="5.0.1" />

		<!-- Rate Limiting -->
		<PackageReference Include="AspNetCoreRateLimit" Version="5.0.0" />

		<!-- Search -->
		<PackageReference Include="Elastic.Clients.Elasticsearch" Version="9.3.4" />
		<PackageReference Include="Elastic.Transport" Version="0.15.1" />

		<!-- Storage / External خدمات -->
		<PackageReference Include="AWSSDK.S3" Version="4.0.20.2" />
		<PackageReference Include="Kavenegar" Version="1.2.5" />

		<!-- Utilities -->
		<PackageReference Include="HtmlSanitizer" Version="9.0.892" />
		<PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="9.0.13" />

		<!-- Cloud Secrets -->
		<PackageReference Include="Azure.Identity" Version="1.11.4" />
		<PackageReference Include="Azure.Security.KeyVault.Secrets" Version="4.6.0" />

	</ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Domain\Domain.csproj" />
    <ProjectReference Include="..\SharedKernel\SharedKernel.csproj" />
  </ItemGroup>

</Project>
